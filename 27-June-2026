# LeetCode 3020

## Pattern
HashMap + Math

## Trick
Handle 1 separately.

## Mistakes
- Overflow
- Forgot center
- Infinite loop

## Complexity
Time: O(n)

## Code

class Solution {
    public int maximumLength(int[] nums) {
        HashMap<Long, Integer> map = new HashMap<>();
         int res=1;
         for( int i=0;i<nums.length;i++){
             map.put( (long)nums[i], map.getOrDefault((long)nums[i] , 0)+1);
         }
         for( long num:map.keySet()){

            // handle 1 seperately 
            if(num==1){
                int cnt = map.get(1L);
                if(cnt%2==0){
                    res=Math.max(res, cnt-1);
                }else {
                     res= Math.max(res, cnt);
                }
                      continue;
              
            }
           long curr=num;
           int  ans =0;
         
           while (map.containsKey(curr) && map.get(curr) > 1) {
                ans += 2;
                curr = curr * curr;
            }


  // final adjustment based on whether the last reached value exists at all
            ans += map.containsKey(curr) ? 1 : -1;
            
             res= Math.max(res, ans);
         }
          return res;
    }
}
